rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user doc
    match /User/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Subscriptions — user can only read their own
    match /Subscription/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // only Cloud Functions can write
    }

    // Transactions — user can only read their own
    match /Transaction/{txid} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // only Cloud Functions can write
    }

    // Products, PriceEntries, Stores — public read, auth write
    match /Product/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /PriceEntry/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /Store/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shopping lists — only owner
    match /ShoppingList/{id} {
      allow read, write: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
